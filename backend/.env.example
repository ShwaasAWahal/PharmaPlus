# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development
PORT=5000

# ── Security ───────────────────────────────────────────────────────────────────
SECRET_KEY=super-secret-key-change-me
JWT_SECRET_KEY=jwt-secret-key-change-me
JWT_ACCESS_EXPIRES_HOURS=8
JWT_REFRESH_EXPIRES_DAYS=30

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (development default — no setup needed)
DATABASE_URL=sqlite:///pharmacy_dev.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/pharmacy_db

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@pharmacy.com
ALERT_RECIPIENTS=admin@pharmacy.com,manager@pharmacy.com

# ── ML Service ─────────────────────────────────────────────────────────────────
ML_SERVICE_BASE_URL=http://ml-service:8000
ML_SERVICE_TIMEOUT=30
ML_SERVICE_API_KEY=

# ── Business Rules ─────────────────────────────────────────────────────────────
LOW_STOCK_THRESHOLD=10
EXPIRY_ALERT_DAYS=30

# ── Scheduler ──────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Asia/Kolkata
