            "url": "{{base_url}}/api/medicines/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"selling_price\": 14.00,\n  \"mrp\": 16.00\n}"
            }
          }
        },
        {
          "name": "Scan Barcode",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
