            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sun Pharma Distributors\",\n  \"contact_person\": \"Raj Kumar\",\n  \"phone\": \"9876543210\",\n  \"email\": \"raj@sunpharma.com\",\n  \"payment_terms\": \"Net 30\"\n}"
            }
          }
        },
        {
          "name": "Add Branch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/medicines/branches",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Downtown Branch\",\n  \"address\": \"456 Park Avenue, Mumbai\",\n  \"phone\": \"0221234567\",\n  \"email\": \"downtown@pharmacy.com\",\n  \"license_number\": \"MH-PHARM-002\",\n  \"manager_name\": \"Priya Sharma\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "List Inventory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/inventory?branch_id=1&include_expired=false",
              "host": ["{{base_url}}"],
              "path": ["api", "inventory"],
              "query": [
                { "key": "branch_id", "value": "1" },
                { "key": "include_expired", "value": "false" }
              ]
