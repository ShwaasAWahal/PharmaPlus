            }
          }
        },
        {
          "name": "Adjust Stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/inventory/1/adjust",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delta\": -5,\n  \"reason\": \"damaged stock removed\"\n}"
            }
          }
        },
        {
          "name": "Expiring Soon",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/inventory/alerts/expiring?days=30&branch_id=1"
          }
        },
        {
          "name": "Low Stock",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/inventory/alerts/low-stock?branch_id=1"
          }
        },
        {
